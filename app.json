{
  "expo": {
    "name": "DΔemon",
    "slug": "carnet-mobile",
    "version": "1.0.0",
    "scheme": "carnet",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.carnet.mobile",
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.carnet.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#030508",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        {
          "enableFTS": true
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Autoriser Carnet a acceder a Face ID pour proteger tes donnees locales."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Autoriser Carnet a utiliser Face ID pour deverrouiller tes donnees locales."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ],
      "expo-font",
      "expo-sharing",
      [
        "expo-audio",
        {
          "microphonePermission": "Autoriser Carnet à utiliser le microphone pour enregistrer des mémos vocaux."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9abd9aa4-4355-47b1-80db-25734cd4e1bb"
      }
    },
    "owner": "dapihkal"
  }
}
